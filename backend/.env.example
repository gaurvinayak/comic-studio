# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8004
FRONTEND_ORIGIN=http://localhost:3002

# ── Database ───────────────────────────────────────────────────────────────
MONGO_URL=mongodb://127.0.0.1:27017
DB_NAME=comic_studio

# ── Storage ────────────────────────────────────────────────────────────────
# Where generated images / exports are written (local blob store).
STORAGE_DIR=./storage

# ── AI keys (reuse your existing keys) ─────────────────────────────────────
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
REPLICATE_API_TOKEN=

# ── Models ─────────────────────────────────────────────────────────────────
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o

# Which provider writes story/script text: gemini | anthropic | openai
STORY_PROVIDER=gemini

# ── Generation tuning ──────────────────────────────────────────────────────
SCRIPT_TEMPERATURE=0.85
MAX_RETRIES=3

# ── Auth (Phase 7 multi-user) ──────────────────────────────────────────────
# false = single local user, no login (frictionless local dev).
# true  = email/password accounts. The FIRST account to register adopts any
#         comics created in local mode, so you don't lose your work.
AUTH_ENABLED=false
SESSION_TTL_DAYS=30
DEFAULT_USER_ID=local-user
